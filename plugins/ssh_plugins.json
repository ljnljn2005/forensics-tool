{
    "默认基础信息": [
        {
            "name": "进程信息 (ps)",
            "cmd": "ps aux"
        },
        {
            "name": "网络端口 (netstat)",
            "cmd": "netstat -ntlp || ss -ntlp"
        },
        {
            "name": "当前登录用户 (w)",
            "cmd": "w"
        },
        {
            "name": "系统信息 (uname)",
            "cmd": "uname -a"
        },
        {
            "name": "磁盘挂载 (df)",
            "cmd": "df -h"
        }
    ],
    "面板管理端解析": [
        {
            "name": "宝塔面板 (BT)",
            "cmd": "echo '面板入口:'; cat /www/server/panel/data/admin_path.pl 2>/dev/null; echo '\n面板端口:'; cat /www/server/panel/data/port.pl 2>/dev/null; echo '\n面板密码信息:'; cat /www/server/panel/default.pl 2>/dev/null; echo '\n\nBT命令行信息:'; sudo bt default 2>/dev/null",
            "type": "SSH命令"
        },
        {
            "name": "1Panel 面板",
            "cmd": "sudo 1pctl user-info 2>/dev/null || echo '未找到 1Panel'",
            "type": "SSH命令"
        }
    ],
    "时间与时区": {
        "name": "时间与时区",
        "author": "ljn",
        "description": "2025四川取证DLC",
        "blocks": [
            {
                "name": "查看时区",
                "cmd": "timedatectl",
                "type": "SSH命令",
                "module": "linux",
                "category": ""
            },
            {
                "name": "列出所有时区",
                "cmd": "timedatectl list-timezones",
                "type": "SSH命令",
                "module": "linux",
                "category": ""
            },
            {
                "name": "（兼容）读取时区文件",
                "cmd": "cat /etc/timezone",
                "type": "SSH命令",
                "module": "linux",
                "category": ""
            },
            {
                "name": "查看当前时间",
                "cmd": "date",
                "type": "SSH命令",
                "module": "linux",
                "category": ""
            }
        ]
    },
    "Linux内核版本号": {
        "name": "Linux内核版本号",
        "author": "ljnljn",
        "description": "FIC DLC",
        "blocks": [
            {
                "name": "系统 Linux 内核版本号",
                "cmd": "data\\misc\\recovery\\proc\\version",
                "type": "文件提取",
                "module": "android",
                "category": ""
            }
        ]
    },
    "1Panel提取v1.0": {
        "name": "1Panel提取v1.0",
        "author": "ljnljn",
        "description": "四川取证DLC",
        "blocks": [
            {
                "name": "用户信息/安全入口",
                "cmd": "1pctl user-info",
                "type": "SSH命令",
                "module": "linux",
                "category": ""
            },
            {
                "name": "版本",
                "cmd": "1pctl version",
                "type": "SSH命令",
                "module": "linux",
                "category": ""
            }
        ]
    },
    "docker提取v1.0": {
        "name": "docker提取v1.0",
        "author": "ljn",
        "description": "docker取证的搜集",
        "blocks": [
            {
                "name": "查看运行中容器",
                "cmd": "docker ps",
                "type": "SSH命令",
                "module": "linux",
                "category": ""
            },
            {
                "name": "查看所有容器",
                "cmd": "docker ps -a",
                "type": "SSH命令",
                "module": "linux",
                "category": ""
            },
            {
                "name": "查看所有镜像",
                "cmd": "docker images",
                "type": "SSH命令",
                "module": "linux",
                "category": ""
            },
            {
                "name": "显示磁盘使用情况",
